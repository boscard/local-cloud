{
  "backend": "libvirt",
  "uri": "qemu:///system",
  "network": {
    "name": "test-net",
    "ip": {
      "address": "192.168.210.1",
      "prefix": 24,
      "dhcp": {
        "start": "192.168.210.200",
        "end": "192.168.210.254"
      }
    }
  },
  "storage": {
    "pool": "cloudinit",
    "images": {
      "ubuntu": {
        "family": "debian",
        "img": "ubuntu-noble.qcow2",
        "src": "https://cloud-images.ubuntu.com/noble/20260217/noble-server-cloudimg-amd64.img",
        "sha256sum": "e8d6f52ed2f4da39e9194b6cd6b050ecb4fe50648819045d0aa8ae1f109a8d91"
      },
      "debian": {
        "family": "debian",
        "img": "debian13.qcow2",
        "src": "https://cloud.debian.org/images/cloud/trixie/20260220-2394/debian-13-generic-amd64-20260220-2394.qcow2",
        "sha512sum": "8e7becf9843224e31a271df5eb6aa90a8077642786996f88f299d4f16043c9bfc563a74437ebfe17990c58362176c309cc61c6f09a83f1c274d799dd02997d4d"
      }
    }
  },
  "instances": {
    "project": "test",
    "vms": {
      "vm-1": {
        "type": "debian",
        "cpu": 1,
        "memory": 2048,
        "storage": "50G"
      },
      "vm-2": {
        "type": "ubuntu",
        "cpu": 2,
        "memory": 4096,
        "storage": "20G"
      }
    }
  },
  "ansible": {
    "all": {
      "hosts": {
        "vm-1": {
          "ansible_ssh_extra_args": "-o StrictHostKeyChecking=no"
        },
        "vm-2": {
          "ansible_ssh_extra_args": "-o StrictHostKeyChecking=no"
        }
      },
      "all-in-one": {
        "hosts": {
          "mx-1": {},
          "mx-2": {}
        }
      }
    }
  }
}
